# Neon Postgres (auto-populated when you link a Neon DB in Vercel)
DATABASE_URL=

# Shared password for login
AUTH_PASSWORD=changeme

# JWT secret (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-string

# API key for scanner-to-app communication (generate with: openssl rand -hex 16)
SCANNER_API_KEY=change-me-to-a-random-key
